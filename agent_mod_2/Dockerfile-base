FROM ghcr.io/hdl/sim/osvb
WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential clang bison flex libfl-dev \
        libreadline-dev gawk tcl-dev libffi-dev \
        git pkg-config \
        libboost-system-dev libboost-python-dev \
        libboost-filesystem-dev zlib1g-dev \
        python3 python3-venv python3-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Build Yosys 0.61 from source
RUN git clone --recurse-submodules --branch v0.61 https://github.com/YosysHQ/yosys.git /tmp/yosys && \
    cd /tmp/yosys && \
    make -j2 && \
    make install && \
    rm -rf /tmp/yosys

RUN python3 -m venv /app/venv
RUN /app/venv/bin/pip install --no-cache-dir \
    requests pyyaml openai google-genai